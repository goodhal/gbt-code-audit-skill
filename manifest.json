{
  "name": "code-security-audit",
  "version": "1.0.0",
  "description": "基于中国国家标准的代码安全审计技能，支持多语言代码安全漏洞检测",
  "author": "Code Audit Team",
  "tags": ["security", "code-audit", "gbt", "vulnerability-detection"],
  "keywords": ["code security", "audit", "vulnerability", "gbt", "china standard"],
  "icon": "https://trae-api-cn.mchost.guru/api/ide/v1/text_to_image?prompt=code%20security%20audit%20shield%20icon&image_size=square",
  "requirements": {
    "python": ">=3.7"
  },
  "main": "skill.py",
  "tools": [
    {
      "name": "detect_language",
      "description": "检测代码目录使用的语言，返回语言列表和对应的标准",
      "parameters": {
        "type": "object",
        "properties": {
          "target": {
            "type": "string",
            "description": "目标代码目录路径"
          }
        },
        "required": ["target"]
      }
    },
    {
      "name": "get_standards",
      "description": "获取语言对应的审计标准",
      "parameters": {
        "type": "object",
        "properties": {
          "languages": {
            "type": "array",
            "items": {"type": "string"},
            "description": "语言列表（可选）"
          },
          "target": {
            "type": "string",
            "description": "目标目录（可选，用于自动检测语言）"
          }
        }
      }
    },
    {
      "name": "get_rules",
      "description": "获取标准的完整规则列表",
      "parameters": {
        "type": "object",
        "properties": {
          "standard": {
            "type": "string",
            "description": "标准代码：34943/34944/34946/39412",
            "default": "34944"
          },
          "format": {
            "type": "string",
            "enum": ["summary", "full"],
            "description": "输出格式",
            "default": "summary"
          }
        },
        "required": ["standard"]
      }
    },
    {
      "name": "scan",
      "description": "执行工具扫描（SpotBugs 字节码扫描）",
      "parameters": {
        "type": "object",
        "properties": {
          "target": {
            "type": "string",
            "description": "目标代码目录路径"
          },
          "bytecode": {
            "type": "boolean",
            "description": "是否执行字节码扫描",
            "default": false
          }
        },
        "required": ["target"]
      }
    },
    {
      "name": "get_report_template",
      "description": "返回标准的报告模板，供生成报告时参考",
      "parameters": {
        "type": "object",
        "properties": {}
      }
    },
    {
      "name": "audit_code",
      "description": "使用 LLM 对代码进行安全审计",
      "parameters": {
        "type": "object",
        "properties": {
          "target": {
            "type": "string",
            "description": "目标代码目录路径"
          },
          "languages": {
            "type": "array",
            "items": {"type": "string"},
            "description": "代码语言（可选）"
          },
          "standards": {
            "type": "array",
            "items": {"type": "string"},
            "description": "审计标准（可选）"
          }
        },
        "required": ["target"]
      }
    }
  ]
}